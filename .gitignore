# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# pm2 / runtime logs
/logs
*.log

# heavy assets — uploaded to the server via rsync, not via git
/public/villages/

# WIP design notes / scratch
/.stitch/

# Source photos (~2 GB) — local working folder, never deploy
/Проекты с фото/

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
